# ============================================================
# Jemi — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. NEVER commit secrets.
# ============================================================

# --- Postgres (Neon) ---
# From your Neon dashboard. Format:
#   postgresql://<user>:<password>@<host>/<database>?sslmode=require
# Neon's connection string already includes ?sslmode=require — keep it.
DATABASE_URL=

# --- JWT signing ---
# Generate with:  openssl rand -base64 32
# Used by jose HS256 to sign the auth cookie. Don't rotate without
# invalidating sessions.
JWT_SECRET=

# --- Cloudinary ---
# From your Cloudinary dashboard. CLOUD_NAME is used in URL transforms,
# the others sign uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Paystack ---
# Test keys start with sk_test_ / pk_test_, live keys with sk_live_ / pk_live_.
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin seed ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=