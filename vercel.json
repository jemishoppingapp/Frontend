{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": [
    "fra1"
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-orders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/escrow-jobs",
      "schedule": "0 3 * * *"
    }
  ]
}
